{
  "name": "react-vite-ts-template",
  "private": true,
  "version": "0.0.17",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "mock": "node mock-server/index.js",
    "dev-server": "node mock-server/index.js && vite",
    "build": "yarn typegen && tsc && vite build",
    "typegen": "npx @chakra-ui/cli typegen src/shared/theme/index.ts",
    "preview": "vite preview",
    "version:patch": "commit-and-tag-version --release-as patch",
    "version:minor": "commit-and-tag-version --release-as minor",
    "version:major": "commit-and-tag-version --release-as major",
    "cz": "cz",
    "lint": "npx eslint . --fix",
    "lint:fsd": "steiger src",
    "test": "vitest",
    "test:ci": "vitest --reporter=junit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.(js|jsx|ts|tsx)": [
      "yarn run lint"
    ]
  },
  "resolutions": {
    "@zag-js/core": "1.35.2",
    "@zag-js/dom-query": "1.35.2",
    "@zag-js/auto-resize": "1.35.2",
    "@zag-js/splitter": "1.35.2"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.33.0",
    "@emotion/react": "^11.14.0",
    "@nextui-org/react": "^2.2.6",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.18",
    "aria-hidden": "^1.2.6",
    "autoprefixer": "^10.4.16",
    "axios": "^1.3.3",
    "crypto-js": "^4.1.1",
    "focus-trap": "^8.0.0",
    "framer-motion": "^12.34.0",
    "lottie": "^0.0.1",
    "lottie-react": "^2.4.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^4.0.4",
    "react-hook-form": "^7.43.2",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.8.0",
    "tailwind-config": "^0.1.2",
    "tailwindcss": "^3.3.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@feature-sliced/steiger-plugin": "^0.5.7",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/crypto-js": "^4.1.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-c8": "^0.30.0",
    "@vitest/coverage-istanbul": "^0.30.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "babel-plugin-react-compiler": "^1.0.0",
    "commit-and-tag-version": "^12.6.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-airbnb-typescript": "17.1.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "2.25.3",
    "eslint-plugin-jsx-a11y": "6.5.1",
    "eslint-plugin-n": "^15.0.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-react": "7.28.0",
    "eslint-plugin-react-hooks": "4.3.0",
    "fast-check": "^4.5.3",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "prettier": "^2.8.7",
    "react-markdown": "^9.0.3",
    "steiger": "^0.5.11",
    "typescript": "5.6.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
